{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "python -m uvicorn src.server:app --host 0.0.0.0 --port 8000 --reload",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "src/server.py": {
      "runtime": "python@3.11"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/server"
    }
  ]
}
